{
  "name": "@monocloud/management-core",
  "version": "0.2.1",
  "description": "MonoCloud Management JavaScript Core Library",
  "keywords": [
    "monocloud",
    "management",
    "sdk",
    "node",
    "core"
  ],
  "homepage": "https://www.monocloud.com",
  "bugs": {
    "url": "https://github.com/monocloud/management-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monocloud/management-js.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": {
    "name": "MonoCloud",
    "email": "support@monocloud.com"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint:es": "eslint src",
    "lint:ts": "tsc",
    "lint": "pnpm run lint:es && pnpm run lint:ts"
  },
  "devDependencies": {
    "eslint": "10.0.0"
  },
  "engines": {
    "node": ">= 11.0.0"
  }
}
